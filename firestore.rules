rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.role in ["admin", "superadmin"];
    }

    function isSuperadmin() {
      return request.auth != null
        && request.auth.token.role == "superadmin";
    }

    match /sitePages/{pageId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /insights/{slug} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /siteSettings/{settingId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /cmsAuditLogs/{logId} {
      allow read: if isSuperadmin();
      allow write: if false;
    }

    match /securityRateLimits/{documentId} {
      allow read, write: if false;
    }

    match /bookingReservations/{documentId} {
      allow read, write: if false;
    }

    match /bookingRequests/{documentId} {
      allow read, write: if false;
    }

    match /bookingAvailabilityCache/{documentId} {
      allow read, write: if false;
    }
  }
}
